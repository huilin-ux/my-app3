                    <div className="flex gap-3">
                      <InputField label="金額" required type="number" placeholder="NT$" defaultValue={editingItem?.baseAmount || ''} />
                      <InputField label="類別" placeholder="例：水電瓦斯" />
                    </div>
                    <div className="flex gap-3">
                      <div className="w-full">
                        <label className="block text-[11px] text-gray-500 font-bold mb-1.5 ml-1">繳費週期</label>
                        <select className="w-full bg-gray-50 border border-gray-100 rounded-xl px-3.5 py-2.5 text-[14px] text-gray-800 focus:outline-none focus:border-[#2B7A57] appearance-none">
                          <option>每個月</option>
                          <option>每兩個月</option>
                          <option>每年</option>
                        </select>
                      </div>
                      <InputField label="到期日 (幾號)" required type="number" placeholder="例: 15" defaultValue={editingItem?.dueDate?.split('/')[1] || ''} />
                    </div>
                    <InputField label="提前幾天提醒" type="number" placeholder="例: 5" />
                    <div className="pt-2"><InputField label="備註" placeholder="選填..." defaultValue={editingItem?.note || ''} /></div>
                    {renderColorPicker()}
                  </div>
                )}
              </div>
            </div>
          </div>
        )}

        {/* --- 彈出式 Modal：記錄還款 / 繳費 / 存入 (包含歷史編輯) --- */}
        {paymentModalData && (
          <div className="fixed inset-0 z-50 flex flex-col justify-end items-center">
            <div className="absolute inset-0 bg-black/40 backdrop-blur-[2px] transition-opacity" onClick={() => {setPaymentModalData(null); setEditingHistoryRecord(null);}}></div>
            <div className="w-full max-w-[400px] bg-white rounded-t-[2rem] p-6 relative z-10 shadow-2xl flex flex-col animate-in slide-in-from-bottom-10">
              <div className="flex justify-between items-center mb-5">
                <button onClick={() => {setPaymentModalData(null); setEditingHistoryRecord(null);}} className="text-gray-400 hover:text-gray-600">
                  <X size={24} />
                </button>
                <h3 className="font-bold text-gray-800 text-[17px]">{editingHistoryRecord ? '編輯歷史紀錄' : `記錄${getTerm(paymentModalData.category, 'actionBtn')}`}</h3>
                <div className="w-6"></div>
              </div>

              <div className="bg-gray-50 rounded-2xl p-4 mb-5 border border-gray-100">
                <p className="text-[12px] text-gray-500 mb-1">{paymentModalData.title}</p>
                <div className="flex justify-between items-end">
                  <h4 className="text-2xl font-bold text-[#2B7A57]">NT$ {paymentModalData.dueThisMonth.toLocaleString()}</h4>
                  <span className="text-[11px] text-gray-400">本期應{paymentModalData.category === 'loans' ? '還' : paymentModalData.category === 'goals' ? '存' : '繳'}</span>
                </div>
              </div>

              <div className="space-y-4">
                <InputField 
                  label={`本次${getTerm(paymentModalData.category, 'actionBtn')}金額`} 
                  type="number" 
                  value={paymentAmount}
                  onChange={(e) => setPaymentAmount(e.target.value)}
                />
                
                <div>
                  <label className="block text-[11px] text-gray-500 font-bold mb-1.5 ml-1">{getTerm(paymentModalData.category, 'payerName')}</label>
                  <div className="flex bg-gray-50 rounded-xl p-1 border border-gray-100 mb-2">
                    <button onClick={() => handlePayerTypeChange('dad')} className={`flex-1 py-2 text-[13px] font-bold rounded-lg transition-colors ${payerType === 'dad' ? 'bg-white shadow-sm text-blue-600' : 'text-gray-400'}`}>爸爸</button>
                    <button onClick={() => handlePayerTypeChange('mom')} className={`flex-1 py-2 text-[13px] font-bold rounded-lg transition-colors ${payerType === 'mom' ? 'bg-white shadow-sm text-rose-500' : 'text-gray-400'}`}>媽媽</button>
                    <button onClick={() => handlePayerTypeChange('shared')} className={`flex-1 py-2 text-[13px] font-bold rounded-lg transition-colors ${payerType === 'shared' ? 'bg-white shadow-sm text-gray-800' : 'text-gray-400'}`}>共同</button>
                  </div>
                  
                  {/* 共同分攤展開區域 */}
                  {payerType === 'shared' && (
                    <div className="flex gap-2 animate-in fade-in slide-in-from-top-2">
                      <div className="flex-1 relative">
                        <span className="absolute left-3 top-2.5 text-[12px] text-gray-400">爸</span>
                        <input type="number" value={sharedSplit.dad} onChange={(e) => handleSharedSplitChange('dad', e.target.value)} className="w-full bg-blue-50 border border-blue-100 rounded-xl pl-8 pr-3 py-2 text-[13px] text-blue-600 font-bold focus:outline-none focus:ring-1 focus:ring-blue-300" />
                      </div>
                      <div className="flex-1 relative">
                        <span className="absolute left-3 top-2.5 text-[12px] text-gray-400">媽</span>
                        <input type="number" value={sharedSplit.mom} onChange={(e) => handleSharedSplitChange('mom', e.target.value)} className="w-full bg-rose-50 border border-rose-100 rounded-xl pl-8 pr-3 py-2 text-[13px] text-rose-600 font-bold focus:outline-none focus:ring-1 focus:ring-rose-300" />
                      </div>
                    </div>
                  )}
                </div>

                <div className="flex gap-3">
                  <InputField label="日期" type="text" placeholder="YYYY/MM/DD" value={paymentDate} onChange={(e) => setPaymentDate(e.target.value)} />
                  <InputField label="備註" placeholder="選填" value={paymentNote} onChange={(e) => setPaymentNote(e.target.value)} />
                </div>

                <button 
                  onClick={handlePaymentSubmit}
                  className="w-full bg-[#2B7A57] text-white font-bold py-3.5 rounded-xl shadow-lg shadow-emerald-900/20 mt-2 transition-transform active:scale-[0.98]"
                >
                  {editingHistoryRecord ? '儲存修改' : '確認記錄'}
                </button>
              </div>
            </div>
          </div>
        )}

        {/* 刪除防呆確認彈窗 */}
        {itemToDelete && (
          <div className="fixed inset-0 z-50 flex items-center justify-center">
            <div className="absolute inset-0 bg-black/40 backdrop-blur-[2px]" onClick={() => setItemToDelete(null)}></div>
            <div className="w-full max-w-[320px] bg-white rounded-3xl p-6 relative z-10 shadow-2xl">
              <div className="w-12 h-12 rounded-full bg-rose-100 text-rose-500 flex items-center justify-center mb-4">
                <svg className="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path strokeLinecap="round" strokeLinejoin="round" strokeWidth={2} d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" /></svg>
              </div>
              <h3 className="text-lg font-bold text-gray-800 mb-2">確認刪除資料</h3>
              <p className="text-[13px] text-gray-500 mb-6 leading-relaxed">您確定要刪除 <span className="font-bold text-gray-700">「{itemToDelete.title}」</span> 嗎？<br/>此動作執行後將無法復原。</p>
              <div className="flex gap-3">
                <button onClick={() => setItemToDelete(null)} className="flex-1 py-3 rounded-xl font-bold text-[13px] text-gray-600 bg-gray-100 hover:bg-gray-200">取消</button>
                <button onClick={handleDeleteConfirm} className="flex-1 py-3 rounded-xl font-bold text-[13px] text-white bg-rose-500 hover:bg-rose-600">確認刪除</button>
              </div>
            </div>
          </div>
        )}

        {/* --- Toast 提示 --- */}
        {toastMessage && (
          <div className="fixed bottom-10 left-1/2 -translate-x-1/2 z-[60] animate-in fade-in slide-in-from-bottom-5 duration-300">
            <div className="bg-gray-800/90 backdrop-blur-md text-white px-5 py-2.5 rounded-full shadow-xl flex items-center gap-2 text-[13px] font-bold whitespace-nowrap">
              <span className="w-2 h-2 rounded-full bg-emerald-400"></span>
              {toastMessage}
            </div>
          </div>
        )}

      </div>
    </div>
  );
}
