                    const isSelected = (year === selectedYear && timeMode === 'yearly');
                    return (
                      <button key={year} onClick={() => { setSelectedYear(year); setTimeMode('yearly'); setIsTimeExpanded(false); }} className={`py-3 rounded-2xl text-[13px] font-bold transition-all duration-300 ${isSelected ? 'bg-[#222] text-white shadow-md scale-105' : 'bg-[#FAFAFA] text-[#222] hover:bg-gray-100'}`}>{year}</button>
