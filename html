  const handlePaymentSubmit = () => {
    if (!paymentModalData) return;
    const amountNum = Number(paymentAmount) || 0;
    const now = new Date();

    setLoans(loans.map(l => {
      if (l.id === paymentModalData.id) {
        let newHistory = [...(l.history || [])];
        let amountDiff = amountNum; 

        if (editingHistoryRecord) {
          amountDiff = amountNum - editingHistoryRecord.amount;
          newHistory = newHistory.map(h => h.id === editingHistoryRecord.id ? {
            ...h, date: `${paymentDate} ${h.date.split(' ')[1] || '00:00'}`, amount: amountNum, payerType, sharedSplit: { ...sharedSplit }, note: paymentNote
