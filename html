          const newRecord = {
            id: 'hist_' + Date.now().toString(), 
            date: `${paymentDate} ${String(now.getHours()).padStart(2,'0')}:${String(now.getMinutes()).padStart(2,'0')}`, 
            amount: amountNum, payerType, sharedSplit: { ...sharedSplit }, note: paymentNote
          };
          newHistory = [newRecord, ...newHistory];
        }

        return {
          ...l,
          history: newHistory,
          totalLeft: Math.max(0, (l.totalLeft || 0) - amountDiff)
        };
      }
      return l;
    }));

    setToastMessage(`已${editingHistoryRecord ? '更新' : '記錄'}${getTerm(paymentModalData.category, 'actionBtn')} NT$ ${amountNum.toLocaleString()}`);
    setTimeout(() => setToastMessage(null), 3000);
    setPaymentModalData(null);
    setEditingHistoryRecord(null);
  };

  const handleDeleteHistory = (loanId, record) => {
    setLoans(loans.map(l => {
      if (l.id === loanId) {
        return {
          ...l, 
          history: (l.history || []).filter(h => h.id !== record.id), 
          totalLeft: (l.totalLeft || 0) + record.amount
        };
      }
      return l;
    }));
    setHistoryMenuId(null);
    setToastMessage('紀錄已刪除，並自動重算進度');
    setTimeout(() => setToastMessage(null), 3000);
  };

  const handleDeleteConfirm = () => {
    if (itemToDelete) {
      setLoans(loans.filter(loan => loan.id !== itemToDelete.id));
      setItemToDelete(null);
    }
  };

  const handleSaveRecord = () => {
    setIsAddModalOpen(false);
    setToastMessage(editingItem ? '記錄已更新' : '記錄已新增');
    setTimeout(() => setToastMessage(null), 3000);
    setEditingItem(null); 
  };

  const dynamicLoans = loans.map(loan => {
    const currentMonthHistory = (loan.history || []).filter(h => {
      if(!h.date) return false;
      const [y, m] = h.date.split('/');
      return parseInt(y) === selectedYear && parseInt(m) === selectedMonth;
    });

    const paidThisMonth = currentMonthHistory.reduce((sum, h) => sum + h.amount, 0);
    let dadContrib = 0; let momContrib = 0;
    currentMonthHistory.forEach(h => {
      if (h.payerType === 'dad') dadContrib += h.amount;
      else if (h.payerType === 'mom') momContrib += h.amount;
      else if (h.payerType === 'shared' && h.sharedSplit) {
        dadContrib += (h.sharedSplit.dad || 0);
        momContrib += (h.sharedSplit.mom || 0);
      }
    });

    const dueThisMonth = Math.max(0, (loan.baseAmount || 0) - paidThisMonth);

    let status = 'pending';
    if (paidThisMonth >= (loan.baseAmount || 0) && (loan.baseAmount || 0) > 0) {
      status = 'completed'; 
    } else if (loan.defaultStatus === 'overdue' && paidThisMonth === 0) {
      status = 'overdue'; 
    }

    const progress = loan.originalAmount ? Math.min(100, Math.round(((loan.originalAmount - loan.totalLeft) / loan.originalAmount) * 100)) : 0;

    return {
      ...loan,
      status,
      dueThisMonth,
      paidThisMonth,
      contributions: { dad: dadContrib, mom: momContrib },
      progress
    };
  });

  const filteredByCat = activeCategory === 'all' ? dynamicLoans : dynamicLoans.filter(l => l.category === activeCategory);

  const baseMonthTotal = filteredByCat.reduce((sum, l) => sum + (l.baseAmount || 0), 0);
  const baseMonthPaid = filteredByCat.reduce((sum, l) => sum + l.paidThisMonth, 0);
  const baseMonthUnpaid = filteredByCat.filter(l => l.status === 'pending' || l.status === 'overdue').reduce((sum, l) => sum + l.dueThisMonth, 0);
  
  const activeTotal = timeMode === 'monthly' ? baseMonthTotal : baseMonthTotal * 12;
  const activePaid = timeMode === 'monthly' ? baseMonthPaid : baseMonthPaid * 12; 
  const activeUnpaid = timeMode === 'monthly' ? baseMonthUnpaid : (baseMonthTotal * (12 - selectedMonth) + baseMonthUnpaid);
  const activeProgressPercent = activeTotal > 0 ? Math.round((activePaid / activeTotal) * 100) : 0;
  
