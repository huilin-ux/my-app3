            <div className="text-white/80 text-[11px] mb-4">{getTitle()} • {activeCategory === 'all' ? '全部總覽' : `${categories.find(c => c.id === activeCategory)?.label}總覽`}</div>
            <div className="flex justify-between items-end mb-4">
              <div>
                <p className="text-white/80 text-[12px] mb-1">{prefix}{pTerm}</p>
                <h2 className="text-[34px] leading-none font-bold tracking-tight">NT$ {activeUnpaid.toLocaleString()}</h2>
              </div>
              <div className="text-right">
                <p className="text-white/80 text-[12px] mb-1">{prefix}{cTerm}</p>
                <p className="text-2xl font-bold leading-none">{activeProgressPercent}%</p>
              </div>
            </div>
            <div className="mb-5 border-b border-white/10 pb-5">
              <div className="w-full h-1.5 bg-white/20 rounded-full overflow-hidden mb-2"><div className="h-full bg-white rounded-full transition-all duration-1000 ease-out" style={{ width: `${activeProgressPercent}%` }}></div></div>
              <div className="flex justify-between text-[11px] text-white/80">
                <span>{cTerm} NT${activePaid.toLocaleString()}</span>
                <span>{getTerm(activeCategory, 'pendingGroup')} NT${activeUnpaid.toLocaleString()}</span>
              </div>
            </div>
            <div className="grid grid-cols-2 gap-4 mb-5">
              <div>
                <p className="text-white/80 text-[11px] mb-1">{prefix} vs {comparePrefix}</p>
                <p className={`font-semibold text-[14px] ${periodDiff > 0 ? 'text-rose-300' : 'text-white'}`}>{diffSign} NT$ {Math.abs(periodDiff).toLocaleString()}</p>
                <p className="text-[10px] text-white/60 mt-0.5">{comparePrefix} NT${lastPeriodTotal.toLocaleString()}</p>
              </div>
              <div>
