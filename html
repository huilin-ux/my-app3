              <button key={c.id} onClick={() => setActiveCategory(c.id)} className={`flex-1 py-3 text-[13px] font-bold rounded-2xl transition-all duration-300 ${activeCategory === c.id ? 'bg-white shadow-[0_2px_10px_rgba(0,0,0,0.06)] text-[#222]' : 'text-gray-400 hover:text-gray-600'}`}>{c.label}</button>
            ))}
