  const familyTotal = dadTotal + momTotal;
  const dadPercent = familyTotal > 0 ? Math.round((dadTotal / familyTotal) * 100) : 0;
  const momPercent = familyTotal > 0 ? Math.round((momTotal / familyTotal) * 100) : 0;

  const prefix = timeMode === 'monthly' ? '本月' : '本年';
  const comparePrefix = timeMode === 'monthly' ? '上月' : '去年';
  const pTerm = getTerm(activeCategory, 'pendingSummary');
  const cTerm = getTerm(activeCategory, 'completedSummary');

  const renderColorPicker = () => (
    <div className="mt-4 pt-4 border-t border-gray-100">
      <label className="block text-[11px] text-gray-500 font-bold mb-2 ml-1">顏色標籤</label>
      <div className="flex gap-3 px-1">
