// --- 輔助 UI 元件 ---
const InputField = ({ label, required, type = "text", placeholder, defaultValue, value, onChange }) => (
  <div className="w-full">
    <label className="block text-[11px] text-gray-500 font-bold mb-1.5 ml-1">
      {label} {required && <span className="text-rose-500">*</span>}
    </label>
    <input 
      type={type} 
      placeholder={placeholder}
      defaultValue={defaultValue}
      value={value}
      onChange={onChange}
      className="w-full bg-gray-50 border border-gray-100 rounded-xl px-3.5 py-2.5 text-[14px] text-gray-800 placeholder-gray-400 focus:outline-none focus:border-[#2B7A57] focus:ring-1 focus:ring-[#2B7A57] transition-all"
    />
  </div>
);

const Toggle = ({ checked, onChange }) => (
  <button
    type="button"
    onClick={() => onChange(!checked)}
    className={`relative inline-flex h-6 w-11 shrink-0 items-center rounded-full transition-colors duration-300 ease-in-out focus:outline-none ${checked ? 'bg-[#2B7A57]' : 'bg-gray-200'}`}
  >
    <span className={`inline-block h-4 w-4 transform rounded-full bg-white transition duration-300 ease-in-out shadow-sm ${checked ? 'translate-x-6' : 'translate-x-1'}`} />
  </button>
);

// --- 智慧用詞對應表 ---
const getTerm = (cat, type) => {
  const isAll = cat === 'all';
  const isLoan = cat === 'loans';
  const isGoal = cat === 'goals';
  
  switch(type) {
    case 'pendingGroup': return isLoan ? '未還' : isGoal ? '未存' : isAll ? '未付' : '未繳';
    case 'completedGroup': return isLoan ? '已還' : isGoal ? '已存' : isAll ? '已付' : '已繳';
    case 'pendingSummary': return isLoan ? '待還' : isGoal ? '待存' : '待繳';
    case 'completedSummary': return isLoan ? '已還' : isGoal ? '已存' : isAll ? '已付' : '已繳';
    case 'actionBtn': return isLoan ? '還款' : isGoal ? '存入' : isAll ? '處理' : '標記已繳';
    case 'actionDone': return isLoan ? '已還款' : isGoal ? '已存入' : isAll ? '已付款' : '已繳費';
    case 'actionBtnExtra': return isLoan ? '追加還款' : isGoal ? '繼續存入' : isAll ? '追加紀錄' : '追加繳費';
    case 'payerName': return isGoal ? '出資人' : '付款人';
    default: return '';
  }
};

export default function App() {
  // --- 家庭財務專用狀態 ---
